# MongoDB Atlas connection string — copy this file to `.env` and paste yours.
# Get it from Atlas → Cluster → Connect → Drivers. Add your DB name before the "?".
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/technicalhub?retryWrites=true&w=majority

# Port the API server listens on (the Vite dev proxy forwards /api here).
PORT=4000

# Office 365 SMTP for confirmation emails (leave USER/PASS blank to disable email).
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=Technical Hub
SMTP_BCC=
