# MongoDB Atlas connection for the Technical Hub API server.
# Copy this file to `.env` and fill in your real values (never commit `.env`).
# NOTE: URL-encode special characters in the password (@ = %40, # = %23, : = %3A,
# / = %2F). Example: a password of "p@ss" becomes "p%40ss".
MONGODB_URI=mongodb+srv://<db-username>:<db-password>@<cluster-host>.mongodb.net/technicalhub?retryWrites=true&w=majority&appName=<app-name>

# Port the API server runs on (the Vite dev proxy forwards /api here).
PORT=4000

# Secret used to sign admin login tokens. Use a long random string.
JWT_SECRET=<generate-a-long-random-string>

# ---- Office 365 SMTP for confirmation emails ----
# Fill SMTP_USER + SMTP_PASS to turn on emails. Until then, registrations still
# work and simply skip the email. SMTP_BCC is optional (a copy to the admin).
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=Technical Hub
SMTP_BCC=

# ---- Microsoft Graph (app-only) — PREFERRED send path ----
# This is the method the organization uses. When all four values below are set,
# confirmation emails are sent through Microsoft Graph from ORG_EMAIL (the SMTP_*
# block above is only a fallback). Requirements:
#   - An Azure app registration with the "Mail.Send" APPLICATION permission +
#     admin consent granted.
#   - ORG_EMAIL = the mailbox it sends FROM (e.g. noreply@technicalhub.io).
# The code also accepts GRAPH_TENANT_ID / GRAPH_CLIENT_ID / GRAPH_CLIENT_SECRET /
# GRAPH_SENDER as aliases if you prefer the prefixed names.
TENANT_ID=<azure-tenant-id>
CLIENT_ID=<azure-app-client-id>
CLIENT_SECRET=<azure-app-client-secret-VALUE>
ORG_EMAIL=<sending-mailbox@technicalhub.io>
GRAPH_FROM_NAME=Technical Hub
GRAPH_BCC=

# ---- Testing toggle (leave unset for real use) ----
# Set to true ONLY while testing, to let the same email/mobile register for a
# webinar repeatedly (so you can re-test the welcome email). Unset/false enforces
# real duplicate blocking.
ALLOW_DUPLICATE_TESTING=
