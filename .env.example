# MongoDB Atlas connection for the Technical Hub API server.
# Copy this file to `.env` and fill in your real values (never commit `.env`).
# NOTE: URL-encode special characters in the password (@ = %40, # = %23, : = %3A,
# / = %2F). Example: a password of "p@ss" becomes "p%40ss".
MONGODB_URI=mongodb+srv://<db-username>:<db-password>@<cluster-host>.mongodb.net/technicalhub?retryWrites=true&w=majority&appName=<app-name>

# Port the API server runs on (the Vite dev proxy forwards /api here).
PORT=4000

# Secret used to sign admin login tokens. Use a long random string.
JWT_SECRET=<generate-a-long-random-string>

# ---- Office 365 SMTP for confirmation emails ----
# Fill SMTP_USER + SMTP_PASS to turn on emails. Until then, registrations still
# work and simply skip the email. SMTP_BCC is optional (a copy to the admin).
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=Technical Hub
SMTP_BCC=

# ---- Microsoft Graph (Office 365) ----
# Modern OAuth send path (Microsoft disabled basic SMTP password login).
# Uses client-credentials: tenant + client id + secret VALUE below.
# STILL NEEDED before it can send:
#   - GRAPH_SENDER  = the Office 365 mailbox it sends FROM (e.g. webinars@domain.com)
#   - "Mail.Send" Application permission + admin consent granted in Azure
GRAPH_TENANT_ID=<azure-tenant-id>
GRAPH_CLIENT_ID=<azure-app-client-id>
GRAPH_CLIENT_SECRET=<azure-app-client-secret>
GRAPH_SENDER=
GRAPH_FROM_NAME=Technical Hub
GRAPH_BCC=
